// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingType {
  DISCOVERY_CALL
  MENTORSHIP_1ON1
  MOCK_INTERVIEW
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

model SiteContent {
  id               String   @id @default("main_site_content")
  heroTag          String   @default("AUTHORITATIVE • DYNAMIC • PREMIUM")
  heroTitle        String   @default("Transform Your Professional Identity With Strategic Mentorship.")
  heroSubtext      String   @default("Empowering high-level professionals to command authority and achieve energetic prestige in their careers through curated LinkedIn strategies and 1:1 wisdom sessions.")
  mentorName       String   @default("Diileep Kumar Sathyadasan")
  mentorRole       String   @default("Strategic Executive Career Mentor")
  mentorImageUrl   String   @default("https://lh3.googleusercontent.com/aida/AP1WRLv39MngB3vq533uO2okUmuM0bGY9vC77Z2YYFJbEH2eM2AsSiEgvH00u9MScf-z3A_7W4HMnF1gZx-GtddmEgEcMY3apFqd5HKCIFr0gzkX63r0tH9IY2BuAZwFgw9roqqb9CXIHMTJd3iGdQwhrvjSGDARHGGtsPyeh8znHqRawq-WvRk3YoV5pcjjln_69cFQd1WEIJBIvNTpjXMTDG8pTn0qb4cDCI1W3fMpvb1wLPIeKC-15Tohq0g")
  stat1Value       String   @default("500+")
  stat1Label       String   @default("MENTEES GUIDED")
  stat2Value       String   @default("₹15Cr+")
  stat2Label       String   @default("SALARY HIKES SECURED")
  stat3Value       String   @default("100+")
  stat3Label       String   @default("LINKEDIN OPTIMIZATIONS")
  stat4Value       String   @default("15+")
  stat4Label       String   @default("YEARS EXPERIENCE")
  updatedAt        DateTime @updatedAt
}

model Mentee {
  id               String               @id @default(uuid())
  name             String
  email            String               @unique
  phone            String?
  linkedinUrl      String?
  currentRole      String?
  company          String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  bookings         Booking[]
  applications     ServiceApplication[]
  payments         Payment[]
  contactMessages  ContactMessage[]
}

model Booking {
  id              String        @id @default(uuid())
  menteeId        String
  mentee          Mentee        @relation(fields: [menteeId], references: [id], onDelete: Cascade)
  type            BookingType   @default(DISCOVERY_CALL)
  serviceName     String
  preferredDate   String
  preferredTime   String
  goals           String?
  status          BookingStatus @default(PENDING)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  payment         Payment?
}

model ServiceApplication {
  id              String        @id @default(uuid())
  menteeId        String
  mentee          Mentee        @relation(fields: [menteeId], references: [id], onDelete: Cascade)
  serviceTitle    String
  priceAmount     Float
  status          String        @default("SUBMITTED")
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  paymentId       String?       @unique
  payment         Payment?      @relation(fields: [paymentId], references: [id])
}

model Payment {
  id                  String             @id @default(uuid())
  menteeId            String
  mentee              Mentee             @relation(fields: [menteeId], references: [id], onDelete: Cascade)
  amount              Float
  currency            String             @default("INR")
  paymentMethod       String             @default("GPAY")
  paymentToken        String?
  transactionId       String             @unique
  status              PaymentStatus      @default(SUCCESS)
  bookingId           String?            @unique
  booking             Booking?           @relation(fields: [bookingId], references: [id])
  serviceApplication  ServiceApplication?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model ContactMessage {
  id          String   @id @default(uuid())
  menteeId    String?
  mentee      Mentee?  @relation(fields: [menteeId], references: [id])
  name        String
  email       String
  subject     String
  message     String
  createdAt   DateTime @default(now())
}
